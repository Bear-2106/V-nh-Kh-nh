@model PagedResult<RoleViewModel>
@{
    ViewData["Title"] = "Vai trò";
}
<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Danh sách vai trò</h4>
        <a asp-action="Create" class="btn btn-success">+ Thêm vai trò</a>
    </div>
    <form method="get" class="filter-row">
        <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Tìm theo tên hoặc quyền..." />
        <button class="btn btn-primary">Lọc</button>
    </form>
    <table class="table table-bordered table-striped">
        <thead class="table-dark"><tr><th>ID</th><th>Tên</th><th>Priority</th><th>Permissions</th><th>System</th><th width="160">Thao tác</th></tr></thead>
        <tbody>
        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr><td>@item.Id</td><td>@item.Name</td><td>@item.Priority</td><td>@item.Permissions</td><td>@(item.IsSystem ? "Yes" : "No")</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn chắc chắn muốn xóa?')">Xóa</a></td></tr>
            }
        }
        else { <tr><td colspan="6" class="text-center">Không có dữ liệu.</td></tr> }
        </tbody>
    </table>
    @await Html.PartialAsync("_Pager", Model)
</div>
