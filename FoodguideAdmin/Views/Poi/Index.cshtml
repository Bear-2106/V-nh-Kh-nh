@model PagedResult<PoiItemViewModel>
@{
    ViewData["Title"] = "Quản lý POIs";
    var categories = ViewBag.Categories as List<string> ?? new();
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Danh sách POIs</h4>
        <a asp-action="Create" class="btn btn-success">+ Thêm POI</a>
    </div>

    <form method="get" class="filter-row">
        <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Tìm theo tên, địa chỉ..." />
        <select name="category" class="form-select">
            <option value="All">Tất cả category</option>
            @foreach (var category in categories)
            {
                <option value="@category" selected="@(Context.Request.Query["category"] == category)">@category</option>
            }
        </select>
        <select name="pageSize" class="form-select">
            @foreach (var size in new[] { 5, 10, 20 })
            {
                <option value="@size" selected="@(Model.PageSize == size)">@size / trang</option>
            }
        </select>
        <button class="btn btn-primary">Lọc</button>
    </form>

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th><th>Tên</th><th>Category</th><th>Địa chỉ</th><th>Tọa độ</th><th>Trạng thái</th><th width="220">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong><div class="text-muted small">@item.Description</div></td>
                    <td>@(string.IsNullOrWhiteSpace(item.Category) ? "Chưa phân loại" : item.Category)</td>
                    <td>@item.Address</td>
                    <td>@item.Latitude, @item.Longitude</td>
                    <td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Đang hoạt động" : "Tạm ẩn")</span></td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bạn chắc chắn muốn xóa POI này?')">Xóa</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="7" class="text-center">Không có dữ liệu.</td></tr>
        }
        </tbody>
    </table>

    @await Html.PartialAsync("_Pager", Model)
</div>
