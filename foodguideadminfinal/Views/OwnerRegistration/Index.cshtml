@model PagedResult<OwnerRegistrationViewModel>
@{
    ViewData["Title"] = "Duyệt Chủ quán";
}

<div class="content-card">
    <h4 class="mb-3">Danh sách đăng ký chủ quán</h4>
    <form method="get" class="filter-row">
        <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Tìm theo họ tên, quán, số điện thoại..." />
        <select name="status" class="form-select">
            @foreach (var status in new[] { "All", "Pending", "Approved", "Rejected" })
            {
                <option value="@status" selected="@(Context.Request.Query["status"] == status)">@status</option>
            }
        </select>
        <button class="btn btn-primary">Lọc</button>
    </form>
    <table class="table table-bordered table-striped">
        <thead class="table-dark"><tr><th>ID</th><th>Họ tên</th><th>Quán</th><th>SĐT</th><th>Email</th><th>Trạng thái</th><th>Ngày tạo</th><th width="160">Thao tác</th></tr></thead>
        <tbody>
        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Id</td><td>@item.FullName</td><td>@item.BusinessName</td><td>@item.Phone</td><td>@item.Email</td><td>@item.Status</td><td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-success btn-sm">Approve</a>
                        <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Reject</a>
                    </td>
                </tr>
            }
        }
        else { <tr><td colspan="8" class="text-center">Không có dữ liệu.</td></tr> }
        </tbody>
    </table>
    @await Html.PartialAsync("_Pager", Model)
</div>
