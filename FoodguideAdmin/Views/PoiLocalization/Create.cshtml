@model PoiLocalizationEditViewModel
@{
    ViewData["Title"] = "Thêm Bản dịch";
    var pois = ViewBag.Pois as List<PoiItemViewModel> ?? new();
}
<div class="content-card">
    <h4 class="mb-3">Thêm bản dịch POI</h4>
    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
    <form method="post">
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">POI</label><select asp-for="PoiId" class="form-select"><option value="">Chọn POI</option>@foreach (var poi in pois){<option value="@poi.Id">@poi.Name</option>}</select><span asp-validation-for="PoiId" class="text-danger"></span></div>
            <div class="col-md-6"><label class="form-label">Ngôn ngữ</label><input asp-for="Language" class="form-control" placeholder="Ví dụ: en, ja, ko" /><span asp-validation-for="Language" class="text-danger"></span></div>
            <div class="col-12"><label class="form-label">Tên bản dịch</label><input asp-for="LocalizedName" class="form-control" /><span asp-validation-for="LocalizedName" class="text-danger"></span></div>
            <div class="col-12"><label class="form-label">Mô tả bản dịch</label><textarea asp-for="LocalizedDescription" class="form-control" rows="4"></textarea></div>
            <div class="col-12"><label class="form-label">Audio URL</label><input asp-for="AudioUrl" class="form-control" /></div>
        </div>
        <div class="mt-4"><button class="btn btn-primary">Lưu</button> <a asp-action="Index" class="btn btn-secondary">Quay lại</a></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
