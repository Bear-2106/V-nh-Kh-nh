@model dynamic
@{
    var currentQuery = Context.Request.Query.ToDictionary(x => x.Key, x => x.Value.ToString());
    var pagerModel = Model;
}

@if (pagerModel != null && (int)pagerModel.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-end">
            @for (var i = 1; i <= (int)pagerModel.TotalPages; i++)
            {
                currentQuery["page"] = i.ToString();
                var queryString = string.Join("&", currentQuery.Select(x => $"{Uri.EscapeDataString(x.Key)}={Uri.EscapeDataString(x.Value)}"));
                <li class="page-item @(i == (int)pagerModel.Page ? "active" : "")">
                    <a class="page-link" href="?@queryString">@i</a>
                </li>
            }
        </ul>
    </nav>
}
