@using Microsoft.Extensions.Configuration
@model PoiDetailsViewModel
@{
    ViewData["Title"] = "Chi tiết quán";

    var configuration = Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration;
    var apiBaseUrl = configuration?["ApiSettings:BaseUrl"] ?? "http://localhost:5074/api/";
    var mediaBaseUrl = apiBaseUrl.EndsWith("/api/", StringComparison.OrdinalIgnoreCase)
        ? apiBaseUrl[..^4].TrimEnd('/')
        : apiBaseUrl.TrimEnd('/');

    string ResolveImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(imageUrl, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return $"{mediaBaseUrl}/{imageUrl.TrimStart('/')}";
    }

    var poiImageUrl = ResolveImageUrl(Model.Poi.ImageUrl);
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@Model.Poi.Name</h4>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="row g-3">
                <div class="col-md-6"><strong>Danh mục:</strong> @(string.IsNullOrWhiteSpace(Model.Poi.Category) ? "Chưa phân loại" : Model.Poi.Category)</div>
                <div class="col-md-6"><strong>Địa chỉ:</strong> @Model.Poi.Address</div>
                <div class="col-md-6"><strong>Tọa độ:</strong> @Model.Poi.Latitude, @Model.Poi.Longitude</div>
                <div class="col-md-6"><strong>Bán kính:</strong> @Model.Poi.Radius</div>
                <div class="col-md-6"><strong>Số người đang truy cập quán này:</strong> @Model.CurrentVisitors</div>
                <div class="col-12"><strong>Mô tả:</strong> @Model.Poi.Description</div>
            </div>
        </div>
        <div class="col-lg-4">
            @if (!string.IsNullOrWhiteSpace(poiImageUrl))
            {
                <button type="button"
                        class="poi-image-trigger"
                        data-bs-toggle="modal"
                        data-bs-target="#poiImageModal"
                        data-image-url="@poiImageUrl"
                        data-image-title="@Model.Poi.Name">
                    <img src="@poiImageUrl" alt="@Model.Poi.Name" class="img-fluid rounded border" style="width: 100%; max-height: 260px; object-fit: cover;" />
                </button>
            }
            else
            {
                <div class="border rounded d-flex align-items-center justify-content-center text-muted" style="height: 260px;">
                    Chưa có ảnh quán
                </div>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextVi)
    || !string.IsNullOrWhiteSpace(Model.Poi.TtsTextEn)
    || !string.IsNullOrWhiteSpace(Model.Poi.TtsTextZh)
    || !string.IsNullOrWhiteSpace(Model.Poi.TtsTextFr)
    || !string.IsNullOrWhiteSpace(Model.Poi.TtsTextRu))
{
    <div class="content-card">
        <h5>Nội dung TTS</h5>
        <div class="row g-3">
            @if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextVi))
            {
                <div class="col-12"><strong>VI:</strong> @Model.Poi.TtsTextVi</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextEn))
            {
                <div class="col-md-6"><strong>EN:</strong> @Model.Poi.TtsTextEn</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextZh))
            {
                <div class="col-md-6"><strong>ZH:</strong> @Model.Poi.TtsTextZh</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextFr))
            {
                <div class="col-md-6"><strong>FR:</strong> @Model.Poi.TtsTextFr</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Poi.TtsTextRu))
            {
                <div class="col-md-6"><strong>RU:</strong> @Model.Poi.TtsTextRu</div>
            }
        </div>
    </div>
}

<div class="content-card">
    <h5>Danh sách món ăn của quán</h5>
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên món</th>
                <th>Giá</th>
                <th>Trạng thái</th>
                <th>Hình ảnh</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Foods.Any())
        {
            foreach (var item in Model.Foods)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>@(item.IsAvailable ? "Còn bán" : "Ngưng bán")</td>
                    <td style="width: 140px;">
                        @if (!string.IsNullOrWhiteSpace(poiImageUrl))
                        {
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary js-open-poi-image"
                                    data-bs-toggle="modal"
                                    data-bs-target="#poiImageModal"
                                    data-image-url="@poiImageUrl"
                                    data-image-title="@Model.Poi.Name">
                                Xem ảnh
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center">Quán này chưa có món ăn.</td></tr>
        }
        </tbody>
    </table>
</div>

<div class="modal fade" id="poiImageModal" tabindex="-1" aria-labelledby="poiImageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="poiImageModalLabel">Ảnh quán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <img id="poiImagePreview" src="" alt="" class="img-fluid rounded d-none" />
                <div id="poiImagePreviewError" class="alert alert-warning mb-0 d-none">
                    Không tải được ảnh. Hãy kiểm tra lại đường dẫn ảnh trong dữ liệu POI hoặc dịch vụ ảnh của API.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
}
