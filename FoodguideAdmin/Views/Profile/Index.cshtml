@model ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}
<div class="content-card">
    <h4 class="mb-3">Thông tin tài khoản</h4>
    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
    <form method="post">
        <input asp-for="Id" type="hidden" />
        <input asp-for="Password" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Username</label><input asp-for="Username" class="form-control" /><span asp-validation-for="Username" class="text-danger"></span></div>
            <div class="col-md-6"><label class="form-label">Vai trò</label><input asp-for="Role" class="form-control" readonly /></div>
            <div class="col-12"><label class="form-label">Họ tên</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
        </div>
        <div class="mt-4"><button class="btn btn-primary">Cập nhật hồ sơ</button></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
