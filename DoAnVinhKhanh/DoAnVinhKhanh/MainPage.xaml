<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnVinhKhanh.MainPage"
             BackgroundColor="White">

    <Grid Padding="10" RowSpacing="10"
          BackgroundColor="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="220" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <SearchBar x:Name="PoiSearchBar"
                   Grid.Row="0"
                   HeightRequest="48"
                   TextChanged="OnPoiSearchTextChanged"
                   SearchButtonPressed="OnPoiSearchButtonPressed" />

        <Border Grid.Row="1"
                StrokeThickness="0"
                BackgroundColor="Transparent">
            <Grid>
                <WebView x:Name="MapWebView"
                         HeightRequest="220"
                         Navigating="MapWebView_Navigating" />

                <VerticalStackLayout HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Spacing="8"
                                     Margin="0,0,12,12">

                    <Button Text="⌖"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            FontSize="18"
                            BackgroundColor="White"
                            TextColor="Black"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Clicked="OnCenterMapClicked" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0">
            <CollectionView x:Name="PoiCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnPoiSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5"
                                Padding="10"
                                Stroke="#D9D9D9"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="White">
                            <Grid ColumnDefinitions="90,*"
                                  ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="{Binding DisplayImageSource}"
                                       WidthRequest="90"
                                       HeightRequest="90"
                                       BackgroundColor="#EFEFEF"
                                       Aspect="AspectFill" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4">
                                    <Label Text="{Binding DisplayName}"
                                           FontSize="18"
                                           TextColor="Black"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding DisplayDescription}"
                                           FontSize="14"
                                           TextColor="Black"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding DisplayDistanceText}"
                                           FontSize="13"
                                           TextColor="Black" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Border x:Name="MiniTtsBar"
                Grid.Row="3"
                Margin="10,0,10,10"
                Padding="10"
                BackgroundColor="White"
                Stroke="#D9D9D9"
                StrokeShape="RoundRectangle 14"
                IsVisible="False">

            <HorizontalStackLayout Spacing="10"
                                   VerticalOptions="Center">

                <Button x:Name="PauseTtsButton"
                        Text="⏹"
                        WidthRequest="42"
                        HeightRequest="42"
                        CornerRadius="21"
                        FontSize="16"
                        BackgroundColor="#F2F2F2"
                        TextColor="Black"
                        Clicked="OnStopTtsClicked" />

                <Label x:Name="NowPlayingLabel"
                       Text="Chưa đọc thuyết minh"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation"
                       HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
