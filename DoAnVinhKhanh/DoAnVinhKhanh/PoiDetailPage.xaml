<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnVinhKhanh.PoiDetailPage"
             Title=" "
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12"
                             BackgroundColor="White">
            <Label x:Name="NameLabel" FontSize="28" FontAttributes="Bold" TextColor="Black" />
            <Label x:Name="DescriptionLabel" FontSize="18" TextColor="Black" />
            <Label x:Name="LatitudeLabel" FontSize="16" TextColor="Black" />
            <Label x:Name="LongitudeLabel" FontSize="16" TextColor="Black" />
            <Label x:Name="RadiusLabel" FontSize="16" TextColor="Black" />
            <Button x:Name="OpenMapButton"
                    Clicked="OnOpenMapClicked" />
            <Image x:Name="PoiImage"
                    HeightRequest="220"
                    Aspect="AspectFill" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
