@model PoiEditViewModel
@{
    ViewData["Title"] = "Thêm quán ăn";
}

<div class="content-card">
    <h4 class="mb-3">Thêm mới quán ăn</h4>
    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
    <form method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Tên quán</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="col-md-6"><label class="form-label">Danh mục</label><input asp-for="Category" class="form-control" /></div>
            <div class="col-12"><label class="form-label">Mô tả</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label">Địa chỉ</label><input asp-for="Address" class="form-control" /></div>
            <div class="col-md-3"><label class="form-label">Latitude</label><input asp-for="Latitude" type="text" class="form-control" placeholder="Để trống = 0" /><span asp-validation-for="Latitude" class="text-danger"></span></div>
            <div class="col-md-3"><label class="form-label">Longitude</label><input asp-for="Longitude" type="text" class="form-control" placeholder="Để trống = 0" /><span asp-validation-for="Longitude" class="text-danger"></span></div>
            <div class="col-md-4"><label class="form-label">Bán kính</label><input asp-for="Radius" type="text" class="form-control" placeholder="Để trống = 50" /><span asp-validation-for="Radius" class="text-danger"></span></div>
            <div class="col-md-8"><label class="form-label">Image URL</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-12"><label class="form-label">Nội dung TTS (VI)</label><textarea asp-for="TtsTextVi" class="form-control" rows="3" placeholder="Để trống sẽ lấy từ mô tả"></textarea></div>
            <div class="col-md-6"><label class="form-label">TTS (EN)</label><textarea asp-for="TtsTextEn" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">TTS (ZH)</label><textarea asp-for="TtsTextZh" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">TTS (FR)</label><textarea asp-for="TtsTextFr" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">TTS (RU)</label><textarea asp-for="TtsTextRu" class="form-control" rows="2"></textarea></div>
            <div class="col-12"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Đang hoạt động</label></div></div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
