<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnVinhKhanh.MainPage">

    <Grid Padding="10" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="220" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="Transparent">
            <WebView x:Name="MapWebView"
                     HeightRequest="220" />
        </Border>

        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0">
            <CollectionView x:Name="PoiCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnPoiSelected"
                            InputTransparent="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5"
                                Padding="10"
                                Stroke="#D9D9D9"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="White">
                            <Grid ColumnDefinitions="90,*"
                                  ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="{Binding DisplayImageSource}"
                                       WidthRequest="90"
                                       HeightRequest="90"
                                       BackgroundColor="#EFEFEF"
                                       Aspect="AspectFill" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding Description}"
                                           FontSize="14"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding Distance, StringFormat='Khoảng cách: {0:F2} km'}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>
