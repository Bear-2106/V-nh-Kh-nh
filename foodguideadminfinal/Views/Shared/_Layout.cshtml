@using FoodGuideAdmin.Models
@{
    var currentUser = Context.Session.GetString("currentUser");
    var user = string.IsNullOrWhiteSpace(currentUser)
        ? null
        : System.Text.Json.JsonSerializer.Deserialize<AdminSessionUser>(currentUser);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Food Guide Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-shell">
        <aside class="sidebar">
            <div class="brand-block">
                <div class="brand-title">Food Guide</div>
                <div class="brand-subtitle">Admin Panel</div>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Poi" asp-action="Index">Quản lý quán ăn</a>
                <a asp-controller="Food" asp-action="Index">Quản lý món ăn</a>
                <a asp-controller="OwnerRegistration" asp-action="Index">Duyệt chủ quán</a>
                <a asp-controller="PoiSubmission" asp-action="Index">Duyệt bài đăng</a>
                <a asp-controller="AdminUsers" asp-action="Index">Tài khoản Admin</a>
                <a asp-controller="AuditLog" asp-action="Index">Audit Logs</a>
                <a asp-controller="Profile" asp-action="Index">Hồ sơ cá nhân</a>
                <a asp-controller="ChangePassword" asp-action="Index">Đổi mật khẩu</a>
                <a asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
            </nav>
        </aside>

        <main class="main-panel">
            <div class="topbar">
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>Hệ thống quản trị đồ án Food Guide</p>
                </div>
                <div class="user-chip">
                    <strong>@(user?.FullName ?? "Admin")</strong>
                    <span>@(user?.Role ?? "Admin")</span>
                </div>
            </div>

            @if (TempData["AlertMessage"] != null)
            {
                <div class="alert alert-@TempData["AlertType"] mt-3">
                    @TempData["AlertMessage"]
                </div>
            }

            <div class="page-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
