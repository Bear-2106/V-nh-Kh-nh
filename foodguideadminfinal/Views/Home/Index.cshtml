@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col-md-4"><div class="stat-card stat-blue"><div>Tổng số quán</div><h3>@Model.TotalPois</h3></div></div>
    <div class="col-md-4"><div class="stat-card stat-green"><div>Đơn chủ quán chờ duyệt</div><h3>@Model.PendingRegistrations</h3></div></div>
    <div class="col-md-4"><div class="stat-card stat-red"><div>Tài khoản admin</div><h3>@Model.TotalAdminUsers</h3></div></div>
</div>

<div class="row mt-2">
    <div class="col-md-3"><div class="stat-card stat-blue"><div>Người đang truy cập hệ thống</div><h3>@Model.TotalOnlineUsers</h3></div></div>
    <div class="col-md-3"><div class="stat-card stat-red"><div>Lượt truy cập hôm nay</div><h3>@Model.TotalVisitEventsToday</h3></div></div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="content-card">
            <form method="get" class="filter-row">
                <select name="category" class="form-select">
                    <option value="All">Tất cả danh mục</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category" selected="@(Model.SelectedCategory == category)">@category</option>
                    }
                </select>
                <button class="btn btn-primary">Lọc thống kê</button>
            </form>

            <h5 class="mb-3">Thống kê theo danh mục</h5>
            @if (Model.CategorySummaries.Any())
            {
                foreach (var item in Model.CategorySummaries)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <strong>@item.Category</strong>
                            <span>@item.PoiCount quán (@item.Percentage.ToString("0.0")%)</span>
                        </div>
                        <div class="meter"><span style="width:@item.Percentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted">Chưa có dữ liệu danh mục.</div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card">
            <h5 class="mb-3">Tổng quan hệ thống</h5>
            <ul class="list-group">
                <li class="list-group-item d-flex justify-content-between"><span>Tài khoản admin</span><strong>@Model.TotalAdminUsers</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Quán ăn hiện có</span><strong>@Model.TotalPois</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Người đang truy cập hệ thống</span><strong>@Model.TotalOnlineUsers</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Lượt truy cập hôm nay</span><strong>@Model.TotalVisitEventsToday</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Đơn chủ quán chờ duyệt</span><strong>@Model.PendingRegistrations</strong></li>
            </ul>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="content-card">
            <h5 class="mb-3">Audit log gần đây</h5>
            <table class="table table-striped">
                <thead><tr><th>Action</th><th>Resource</th><th>Thời gian</th></tr></thead>
                <tbody>
                @foreach (var item in Model.RecentAuditLogs)
                {
                    <tr>
                        <td>@item.Action</td>
                        <td>@item.Resource</td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
